# ---- Core ----
APP_NAME=SriniKai
ENV=development               # development | production

# ---- Database ----
# Dev (default): local SQLite file. Prod: Postgres on AWS RDS, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@your-rds-host:5432/srinikai
DATABASE_URL=sqlite:///./srinikai.db

# ---- Auth / Security ----
# Generate a strong secret:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080      # 7 days

# Comma-separated list of allowed frontend origins (CORS).
CORS_ORIGINS=http://localhost:5173,http://localhost:8000,http://127.0.0.1:5500

# Rate limits (requests per window).
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_CHAT=30/minute

# ---- Model backend (llama-server) ----
LLAMA_SERVER_URL=http://localhost:8080
MODEL_NAME=SriniKai
REQUEST_TIMEOUT_SECONDS=120
MAX_INPUT_CHARS=16000
MAX_HISTORY_MESSAGES=20
